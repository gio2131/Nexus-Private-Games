// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: messages
// Fields:
//   - text: string (1-1000 chars) - The message content
//   - username: string (2-20 chars) - The sender's name
//   - timestamp: timestamp (required) - Server-side time
//   - type: string ('message' or 'system') - Message category
//
// Collection: active_users
// Fields:
//   - username: string (2-20 chars) - Unique identifier
//   - lastSeen: timestamp (required) - Heartbeat time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'username', 'timestamp', 'type']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 20 &&
             data.type in ['message', 'system'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'lastSeen']) &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 20;
    }

    // Messages collection
    match /messages/{messageId} {
      // Allow public read for the chat prototype
      allow read: if true; 
      // Allow creation if data is valid (loosened auth check for prototype)
      allow create: if isValidMessage(request.resource.data);
      allow update, delete: if false;
    }

    // Active users collection
    match /active_users/{username} {
      allow read: if true;
      allow create: if isValidUser(request.resource.data) && request.resource.data.username == username;
      allow update: if isValidUser(request.resource.data) && resource.data.username == username;
      allow delete: if resource.data.username == username;
    }
  }
}
